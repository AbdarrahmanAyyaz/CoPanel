ANTHROPIC_API_KEY=sk-ant-...

# Optional: a GitHub Personal Access Token (no scopes needed for public repos).
# Without one, anonymous calls to the GitHub API are rate-limited to 60/hour
# per IP, which is tight for a stage demo. Setting this raises the limit to
# 5000/hour. Generate at https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...
