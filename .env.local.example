# The Panel auto-detects which provider to use:
#   1. If GOOGLE_GENERATIVE_AI_API_KEY (or GEMINI_API_KEY) is set, it uses Gemini.
#   2. Else if ANTHROPIC_API_KEY is set, it uses Anthropic.
#   3. Else, the API routes return an error.
# Set one. Setting both prefers Gemini.

# Gemini (free tier covers most demo use; get a key at https://aistudio.google.com)
GOOGLE_GENERATIVE_AI_API_KEY=...
# GEMINI_API_KEY=...   # alternative name, also accepted

# Anthropic (paid; get a key at https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---

# Specific model IDs (defaults shown)
# GEMINI_MODEL_ID=gemini-2.5-flash
# ANTHROPIC_MODEL_ID=claude-sonnet-4-5

# GitHub Personal Access Token (no scopes needed for public repos).
# Without one, the /api/from-repo route is limited to 60 GitHub API calls
# per hour per IP. With one, the limit becomes 5000/hour.
# GITHUB_TOKEN=ghp_...

# Kill switch — set to "1" to immediately return 503 from all panel routes
# without redeploying. Useful if the demo is being abused.
# PANEL_DISABLED=1
